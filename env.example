# Router admin base URL. Default matches most Movistar HGU routers.
ROUTER_URL=http://192.168.1.1

# Router admin password (login is by password only, no username).
# SECRET — set this via Coolify secrets / your deployment's secret manager,
# never commit a real value here.
ROUTER_PASSWORD=

# Desired LAN DNS server (your Pi-hole / DNS sinkhole address).
DESIRED_DNS=192.168.1.254

# How often to probe the LAN via DHCP DISCOVER. Go duration format
# (e.g. 10m, 30s, 1h).
CHECK_INTERVAL=10m

# Self-hosted ntfy server + topic used for drift/restore notifications.
NTFY_URL=https://ntfy.example.com
NTFY_TOPIC=dns-watchdog

# Path to the append-only JSONL event log (mounted volume in production).
EVENT_LOG_PATH=/data/events.jsonl

# Network interface to send the DHCP DISCOVER on. Optional — if unset, the
# watchdog picks the first interface that is up, non-loopback, and supports
# broadcast. Set this explicitly if auto-detection picks the wrong NIC
# (e.g. a container/VPN interface on a host with multiple NICs).
IFACE=

# SAFETY GATE — default TRUE. When true, the remediator logs into the
# router, reads its current LAN config, and BUILDS the save request, but
# does NOT send it — it only logs the constructed URL (sessionKey/password
# redacted). Use this to verify the constructed request against your real
# router before ever setting it to false. Only set to "false" once you've
# confirmed a DRY_RUN log line looks correct.
DRY_RUN=true
